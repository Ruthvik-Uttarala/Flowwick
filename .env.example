# FlowCart environment template
# Copy this file to `.env.local` and fill in real values.

# ── Supabase (REQUIRED) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Airia AI Agent (REQUIRED for enhancement) ────────────────
# The full pipeline execution URL including the agent GUID
AIRIA_API_URL=https://api.airia.ai/v2/PipelineExecution/your-agent-guid
AIRIA_API_KEY=your-airia-api-key
AIRIA_AGENT_GUID=your-agent-guid

# Optional Airia tuning
AIRIA_API_TIMEOUT_MS=30000

# ── Shopify (fallback — users set their own in Settings) ─────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── Instagram (fallback — users set their own in Settings) ───
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ENABLED=true

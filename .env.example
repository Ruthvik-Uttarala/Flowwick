# FlowCart environment template
# Copy this file to `.env.local` and fill in real values.

# ── Supabase (REQUIRED) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (REQUIRED for OAuth callbacks) ───────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (REQUIRED for enhancement) ────────────────────────
OPENAI_API_KEY=sk-...

# ── Shopify OAuth (REQUIRED for Shopify integration) ─────────
# Create a Shopify app at partners.shopify.com to get these
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ── Instagram (fallback — users set their own in Settings) ───
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ENABLED=true

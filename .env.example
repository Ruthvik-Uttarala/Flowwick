# Flowwick environment template
# Copy this file to `.env.local` and fill in real values.

# -- Supabase (REQUIRED) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- App URL (REQUIRED for OAuth callbacks) -------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- OpenAI (REQUIRED for enhancement) ------------------------
OPENAI_API_KEY=sk-...

# -- Shopify OAuth (REQUIRED for Shopify integration) ---------
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# -- Meta Instagram OAuth (REQUIRED for production onboarding) -
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_TOKEN_ENCRYPTION_KEY=replace-with-a-random-secret

# -- Instagram Runtime Flags ----------------------------------
INSTAGRAM_ENABLED=true
# Legacy env var name retained for backward compatibility:
FLOWCART_ENABLE_INSTAGRAM_DEBUG_FIELDS=false

# -- Legacy Instagram fallback (debug/admin only) -------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
